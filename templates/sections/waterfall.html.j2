<h2 class="section-title">{{ section.title or "Waterfall" }}</h2>
{% for size in section.sizes_pt %}
<div class="waterfall-row">
  <span class="label">{{ size }} pt</span>
  <span class="waterfall-text specimen"
        style="font-family: '{{ section.font_family }}'; font-size: {{ size }}pt;{{ section.style_extra }}">{{ section.text }}</span>
</div>
{% endfor %}
